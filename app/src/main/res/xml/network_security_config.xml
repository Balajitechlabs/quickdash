<?xml version="1.0" encoding="utf-8"?>
<!--
    Network Security Config for QuickDash
    Prohibits cleartext (HTTP) traffic globally — satisfies Google Play Protect.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
    <debug-overrides>
        <trust-anchors>
            <certificates src="user" />
        </trust-anchors>
    </debug-overrides>
</network-security-config>
